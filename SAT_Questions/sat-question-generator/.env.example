# ============================================
# LLM Backend Configuration
# ============================================
# Option A (hosted Zhipu): set ZHIPU_API_KEY only (default base URL is Zhipu)
# ZHIPU_API_KEY=...

# Option B (custom/local OpenAI-compatible backend, e.g. MiniMax on RunPod):
# LLM_BASE_URL=http://127.0.0.1:8000/v1
# If your local endpoint is keyless, leave LLM_API_KEY unset.
# If your endpoint requires auth, set:
# LLM_API_KEY=...

# Optional model overrides for local backends
# LLM_MODEL=minimax-m1
# GENERATION_MODEL=minimax-m1
# EVALUATION_MODEL=minimax-m1

# Optional: Additional API keys for parallel hosted execution
# ZHIPU_API_KEY_2=...
# ZHIPU_API_KEY_3=...

# Required for image generation: Google API key for Gemini (Nano Banana)
GOOGLE_API_KEY=...
