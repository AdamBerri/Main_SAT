# Isolated experiment data root
PREAM_DATA_ROOT=/Users/berri/Desktop/initial_claude_work/SAT_Questions/sat-question-generator/experiments/minimax_pream_loops_v1

# MiniMax endpoint — set to your RunPod proxy URL before running
# Example: https://abc123def-8000.proxy.runpod.net/v1
# The run-pream-blast.sh script overrides this via CLI argument.
MINIMAX_BASE_URL=http://127.0.0.1:8000/v1

# Model names exposed by your MiniMax server
LLM_MODEL=minimax-m1
GENERATION_MODEL=minimax-m1
EVALUATION_MODEL=minimax-m1

# Optional if your local endpoint requires auth
# LLM_API_KEY=...

# Experiment defaults
PREAM_SUBAGENTS=5
PREAM_CONVERGENCE=0.005
MAX_ITERATIONS=12
PREAM_SAMPLES=25
