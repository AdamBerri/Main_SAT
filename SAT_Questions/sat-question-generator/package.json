{
  "name": "@sat-prep/question-generator",
  "version": "1.0.0",
  "description": "PREAM-based self-improving SAT question generation system with SSR evaluation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sat-gen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "generate": "ts-node src/cli.ts generate",
    "evaluate": "ts-node src/cli.ts evaluate",
    "optimize": "ts-node src/cli.ts optimize",
    "setup:minimax-experiment": "node scripts/setup-minimax-experiment.mjs",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "keywords": [
